@model MiProyecto.Models.Videojuego

@{
    ViewData["Title"] = "Agregar Videojuego";
}

<style>
    .page-header {
        border-left: 4px solid #6366f1;
        padding-left: 16px;
        margin-bottom: 28px;
    }
    .page-header h1 { font-weight: 800; margin-bottom: 2px; }
    .page-header p { color: #6b7280; font-size: .93rem; margin: 0; }

    .form-card {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        background: #fff;
        padding: 32px;
        max-width: 520px;
    }
    .form-label {
        font-size: .83rem;
        font-weight: 600;
        color: #374151;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 6px;
    }
    .form-control {
        border: 1px solid #d1d5db;
        border-radius: 7px;
        padding: 9px 12px;
        font-size: .95rem;
        transition: border-color .15s, box-shadow .15s;
    }
    .form-control:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99,102,241,.15);
        outline: none;
    }
    textarea.form-control { min-height: 90px; resize: vertical; }

    .btn-guardar {
        background: #6366f1;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 10px 28px;
        font-size: .95rem;
        font-weight: 600;
        cursor: pointer;
        transition: background .2s;
    }
    .btn-guardar:hover { background: #4f46e5; }

    .btn-cancelar {
        color: #6b7280;
        text-decoration: none;
        font-size: .9rem;
    }
    .btn-cancelar:hover { color: #111; text-decoration: underline; }
</style>

<!-- Encabezado -->
<div class="page-header">
    <h1>Agregar Videojuego</h1>
    <p>Completa los datos del juego que quieres agregar a tu colección.</p>
</div>

<!-- Formulario -->
<div class="form-card">
    <form asp-action="Agregar" method="post">
        <div class="mb-3">
            <label class="form-label">Título</label>
            <input asp-for="Titulo" class="form-control" placeholder="Ej. Devil May Cry 3" />
        </div>
        <div class="mb-3">
            <label class="form-label">Género</label>
            <input asp-for="Genero" class="form-control" placeholder="Ej. Hack and Slash" />
        </div>
        <div class="mb-3">
            <label class="form-label">Consola</label>
            <input asp-for="Consola" class="form-control" placeholder="Ej. PlayStation 2" />
        </div>
        <div class="mb-3">
            <label class="form-label">Año</label>
            <input asp-for="Ano" type="number" class="form-control" placeholder="Ej. 2005" />
        </div>
        <div class="mb-4">
            <label class="form-label">Descripción</label>
            <textarea asp-for="Descripcion" class="form-control" placeholder="Una breve descripción del juego..."></textarea>
        </div>
        <div class="d-flex align-items-center gap-3">
            <button type="submit" class="btn-guardar">Guardar</button>
            <a asp-action="Index" class="btn-cancelar">&larr; Cancelar</a>
        </div>
    </form>
</div>
